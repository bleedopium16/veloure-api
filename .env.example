# Copy this file to ".env" and fill in your real values.
# NEVER commit your real .env file to GitHub.

# MongoDB Atlas connection string (get it from your Atlas cluster → Connect → Drivers)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/veloure?retryWrites=true&w=majority

# Secret used to sign JWT tokens — make this a long random string
JWT_SECRET=change_this_to_a_long_random_secret_string

# Port the server runs on locally
PORT=5000

# Your frontend URL (for CORS). Use http://localhost:5173 in dev.
CLIENT_URL=http://localhost:5173
